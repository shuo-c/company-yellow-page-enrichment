# Supabase connection
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Pipeline defaults
TARGET_LANG=zh-CN
BATCH_SIZE=10
OUT_DIR=out
FIELDS=intro,description
NO_TRANSLATE_FIELDS=company_name,address,website,url

# Translator request mode: keep 1 item per request for stability
TRANSLATE_INPUT_SIZE=1
